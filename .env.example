# ==========================================
# Dream Share - Variáveis de Ambiente
# Copie este arquivo para .env e preencha
# ==========================================

# --- Django ---
SECRET_KEY=troque-por-uma-chave-secreta-forte
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*

# --- CORS ---
CORS_ALLOW_ALL=True
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Banco de Dados (PostgreSQL no Docker) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=dreamshare
DB_USER=dreamshare
DB_PASSWORD=dreamshare_secret
DB_HOST=db
DB_PORT=5432

# --- Email (SMTP) ---
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@dreamshare.com

# --- Docker ---
BACKEND_PORT=8000
RUN_SEED=true
